# Copy this file to `.env.local` (gitignored) and fill in the values.

# -----------------------------------------------------------------------------
# API URL — where the frontend calls the backend.
# -----------------------------------------------------------------------------
# Local dev: point at your FastAPI server.
VITE_API_URL=http://localhost:5050

# In production (Vercel) this is set to the deployed backend origin, e.g.:
# VITE_API_URL=https://bearboard-backend.onrender.com


# -----------------------------------------------------------------------------
# Cloudinary — optional. Lets users upload images directly from the composer.
# -----------------------------------------------------------------------------
# If EITHER of the two values below is missing, the image field falls back to
# "paste a URL" — everything still works, just no in-browser uploads.
#
# Setup (free tier is plenty for a student project):
#   1. Sign up at https://cloudinary.com (free).
#   2. Dashboard → Settings → Upload → "Add upload preset"
#        - Signing Mode: "Unsigned"
#        - (Recommended) set Folder to "bearboard"
#        - (Recommended) restrict allowed formats to jpg,png,webp,gif
#        - (Recommended) enable "Max file size" ~10 MB
#      Save, then copy the preset name.
#   3. From the dashboard header copy your "Cloud name".
#   4. Fill in the two env vars below and restart `npm run dev`.
#
# VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
# VITE_CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset-name
