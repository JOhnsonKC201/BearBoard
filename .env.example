# Copy this file to `.env` and fill in the values. `.env` is gitignored.
# Only two variables are required: DATABASE_URL and SECRET_KEY.

# =============================================================================
# DATABASE_URL — pick ONE of the three patterns below
# =============================================================================

# --- Option A: local SQLite (simplest dev setup, no external service) -------
# Creates backend/bearboard.db on first `alembic upgrade head`.
DATABASE_URL=sqlite:///./bearboard.db

# --- Option B: Supabase (free Postgres; use for staging / demo deploys) -----
# 1. In Supabase dashboard → Connect → copy the Transaction pooler string
# 2. Replace YOUR-PASSWORD with the DB password you set at project creation
#    (reset it at Settings → Database → Reset database password if lost)
# 3. Keep the `postgresql+psycopg2://` scheme (the driver prefix matters)
# 4. Port 6543 = Transaction pooler (required on the free tier).
#    core/database.py auto-switches to NullPool when it sees this hostname.
# DATABASE_URL=postgresql+psycopg2://postgres.<project-ref>:YOUR-PASSWORD@aws-1-us-east-1.pooler.supabase.com:6543/postgres

# --- Option C: self-hosted Postgres or AWS RDS ------------------------------
# DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME

# --- Option D: MySQL / AWS RDS MySQL ----------------------------------------
# DATABASE_URL=mysql+pymysql://USER:PASSWORD@HOST:3306/DBNAME


# =============================================================================
# SECRET_KEY — signs the JWTs issued by /api/auth/login
# =============================================================================
# The server refuses to boot on the old committed placeholder, so set this.
# Generate a long random value for any real deployment:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=dev-only-not-for-production-change-me


# =============================================================================
# ALLOWED_ORIGINS (optional) — comma-separated CORS allow-list
# =============================================================================
# Defaults to local Vite dev (http://localhost:5173) when unset.
# In production set this to the deployed frontend origin, e.g.:
# ALLOWED_ORIGINS=https://bearboard.vercel.app


# =============================================================================
# EMAIL / SMTP — required for "Forgot Password" emails
# =============================================================================
# If SMTP_USER / SMTP_PASSWORD are unset the server logs the reset link
# instead of sending an email (useful for local dev).
#
# Gmail example (use an App Password, not your real password):
#   https://myaccount.google.com/apppasswords
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=yourname@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=BearBoard <yourname@gmail.com>
#
# FRONTEND_URL is used to build the reset link in the email.
# FRONTEND_URL=http://localhost:3000
